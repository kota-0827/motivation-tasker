// Motivation Tasker - Prisma Schema
// 設計メモのER図（User 1-n Category, User 1-n Task, Category 1-n Task）に加え、
// 依頼要件の isCompleted / motivation_level / urgency_level / createdAt を反映しています。

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  totalPoints  Int        @default(0) @map("total_points")

  categories   Category[]
  tasks        Task[]

  @@map("users")
}

model Category {
  id     Int    @id @default(autoincrement())
  name   String

  userId Int    @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  tasks  Task[]

  @@map("categories")
}

model Task {
  id               Int      @id @default(autoincrement())
  title            String

  // 依頼要件の必須フィールド
  isCompleted      Boolean  @default(false) @map("is_completed")
  motivationLevel  Int      @map("motivation_level") // 1-5: このタスクに必要な「やる気」
  urgencyLevel     Int      @map("urgency_level")     // 1-5: ヤバ度（緊急度）
  createdAt        DateTime @default(now()) @map("created_at")

  // 設計メモのER図を補完するフィールド
  deadline         DateTime?
  status           String   @default("TODO") // TODO / DONE / EXPIRED

  categoryId       Int      @map("category_id")
  category         Category @relation(fields: [categoryId], references: [id])

  userId           Int      @map("user_id")
  user             User     @relation(fields: [userId], references: [id])

  @@map("tasks")
}
